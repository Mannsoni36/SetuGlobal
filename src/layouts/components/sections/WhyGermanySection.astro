---
import { getEntryCTM } from "@/lib/contentParser.astro";
import overrideObjects from "@/lib/utils/overrideObjects";

type Reason = { icon?: string; highlight?: string; title: string; description: string };
type SectionType = {
  enable?: boolean;
  badge?: string;
  title?: string;
  description?: string;
  reasons?: Reason[];
};

type Props = { content?: SectionType };

let defaultContent = (
  await getEntryCTM("sections", "why-germany", Astro.currentLocale)
)?.data as unknown as SectionType;

let actualContent = overrideObjects(
  { ...defaultContent },
  Astro.props.content,
) as SectionType;

const { enable = true, reasons } = actualContent ?? {};

if (!enable) return;

// Use only top 4 most impactful reasons
const keyReasons = reasons?.slice(0, 4) ?? [];
---

<section id="why-germany" class="scroll-mt-28 overflow-hidden">

  <!-- Bold header band -->
  <div class="bg-primary py-20 lg:py-28">
    <div class="container">
      <div class="mx-auto max-w-4xl" data-aos="fade-up" data-aos-duration="600">
        <p class="text-secondary mb-3 text-sm font-bold uppercase tracking-[0.25em]">Your Future Destination</p>
        <h2 class="text-4xl font-black text-white leading-tight lg:text-6xl xl:text-7xl">
          Why study<br />
          <span class="text-secondary">in Germany?</span>
        </h2>
        <p class="mt-6 max-w-2xl text-base text-white/60 lg:text-lg">
          Four reasons that make Germany the world's smartest choice for Indian students — and none of them are what you'd expect.
        </p>
      </div>
    </div>
  </div>

  <!-- Editorial reason rows -->
  <div class="bg-[#f5f3ef]">
    {keyReasons.map((reason, i) => (
      <div
        class:list={[
          "border-border-light border-b last:border-0",
          i % 2 === 1 ? "bg-white" : "bg-[#f5f3ef]"
        ]}
        data-aos="fade-up"
        data-aos-delay={i * 80}
        data-aos-duration="500">
        <div class="container">
          <div class="grid grid-cols-1 gap-6 py-10 lg:grid-cols-12 lg:items-center lg:gap-12 lg:py-14">
            <!-- Number -->
            <div class="lg:col-span-1 flex items-center">
              <span class:list={[
                "text-6xl font-black leading-none lg:text-8xl",
                i === 0 ? "text-primary/15" :
                i === 1 ? "text-secondary/25" :
                i === 2 ? "text-primary/15" :
                "text-secondary/25"
              ]}>
                {String(i + 1).padStart(2, "0")}
              </span>
            </div>

            <!-- Highlight + Title -->
            <div class="lg:col-span-4">
              <span class:list={[
                "mb-2 block text-xs font-black uppercase tracking-[0.2em]",
                i % 2 === 0 ? "text-primary" : "text-secondary"
              ]}>
                {reason.highlight}
              </span>
              <h3 class="text-2xl font-black leading-tight text-text-default lg:text-3xl">
                {reason.title}
              </h3>
            </div>

            <!-- Divider (hidden on mobile) -->
            <div class="hidden lg:col-span-1 lg:flex lg:justify-center">
              <div class:list={[
                "h-16 w-px",
                i % 2 === 0 ? "bg-primary/20" : "bg-secondary/30"
              ]}></div>
            </div>

            <!-- Description -->
            <div class="lg:col-span-6">
              <p class="text-text-default/60 text-base leading-relaxed lg:text-lg">
                {reason.description}
              </p>
            </div>
          </div>
        </div>
      </div>
    ))}
  </div>

  <!-- Bottom CTA -->
  <div class="bg-[#f5f3ef] border-t border-border-light">
    <div class="container py-12 flex flex-col items-center gap-5 text-center" data-aos="fade-up" data-aos-duration="400">
      <p class="text-text-default/70 text-base lg:text-lg max-w-xl">
        Still wondering if Germany is right for you? Let's talk — it's free, and it takes 30 minutes.
      </p>
      <a
        href="/#contact"
        class="bg-primary hover:bg-primary/90 inline-block rounded-xl px-8 py-4 text-sm font-bold text-white transition-colors duration-200 lg:text-base">
        Book Your Free Consultation →
      </a>
    </div>
  </div>

</section>
