---
const trades = [
  { icon: "⚡", label: "Electrician" },
  { icon: "🏥", label: "Nurse / Care Worker" },
  { icon: "🚗", label: "Auto Technician" },
  { icon: "🔩", label: "CNC Technician" },
  { icon: "⚙️", label: "Industrial Mechanic" },
  { icon: "💻", label: "IT Specialist" },
  { icon: "📊", label: "Kaufmann / Commerce" },
  { icon: "🏗️", label: "Plant Mechanic" },
];
---

<section class="ausbildung-preview section-spacing-vertical relative overflow-hidden">

  <div class="container">
    <div class="grid grid-cols-1 gap-12 lg:grid-cols-2 lg:items-center lg:gap-20">

      <!-- Text Side -->
      <div data-aos="fade-right" data-aos-duration="600">
        <span class="bg-primary/10 text-primary mb-4 inline-block rounded-full px-4 py-1 text-xs font-bold uppercase tracking-widest">
          Now Offered by Setu Global
        </span>
        <h2 class="mb-5 text-3xl font-black leading-tight text-text-default lg:text-4xl">
          Ausbildung in Germany<br />
          <span class="text-primary">for technical professionals</span>
        </h2>
        <p class="text-text-default/70 mb-5 text-base leading-relaxed">
          If you have a passion for hands-on technical work, Germany's Ausbildung system lets you train at a real German company, earn a monthly stipend of €600 to €1,200, and graduate as a certified professional in 2 to 3.5 years.
        </p>
        <p class="text-text-default/70 text-base leading-relaxed">
          We also offer German language training in India to help you meet the eligibility requirements before you apply.
        </p>
        <div class="mt-8 flex flex-wrap gap-3">
          <a href="/ausbildung/" class="rounded-xl bg-primary px-6 py-3 text-sm font-bold text-white transition-opacity hover:opacity-90">
            Learn About Ausbildung
          </a>
          <a href="/#contact" class="rounded-xl border-2 border-primary/30 px-6 py-3 text-sm font-bold text-primary transition-colors hover:bg-primary/5">
            Book Guidance Call
          </a>
        </div>
      </div>

      <!-- Trade Grid -->
      <div data-aos="fade-left" data-aos-duration="600">
        <div class="grid grid-cols-2 gap-3 sm:grid-cols-4 lg:grid-cols-2 xl:grid-cols-4">
          {trades.map((trade, i) => (
            <div
              class:list={[
                "flex flex-col items-center gap-2 rounded-2xl border bg-white p-4 text-center transition-all duration-300 hover:-translate-y-1 hover:shadow-md",
                i % 2 === 0 ? "border-primary/15" : "border-secondary/15"
              ]}
              data-aos="zoom-in"
              data-aos-delay={i * 50}
              data-aos-duration="400">
              <span class="text-3xl">{trade.icon}</span>
              <span class="text-xs font-bold text-text-default leading-tight">{trade.label}</span>
            </div>
          ))}
        </div>
        <p class="text-text-default/40 mt-4 text-center text-xs">
          And many more technical trades available
        </p>
      </div>

    </div>
  </div>
</section>

<style>
  .ausbildung-preview {
    background-color: #f5f3ef;
    background-image: radial-gradient(circle, #c8bfb0 1px, transparent 1px);
    background-size: 28px 28px;
  }
</style>
