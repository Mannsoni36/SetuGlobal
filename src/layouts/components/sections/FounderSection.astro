---
import { getEntryCTM } from "@/lib/contentParser.astro";
import overrideObjects from "@/lib/utils/overrideObjects";
import { markdownify } from "@/lib/utils/textConverter";
import OptimizedImage from "../utilities/OptimizedImage.astro";

type PersonType = {
  enable?: boolean;
  name?: string;
  role?: string;
  quote?: string;
  bio?: string;
  photo?: string;
  photoAlt?: string;
  initials?: string;
};

type Props = { content?: PersonType };

let founderData = (
  await getEntryCTM("sections", "founder", Astro.currentLocale)
)?.data as unknown as PersonType;

let coFounderData = (
  await getEntryCTM("sections", "co-founder", Astro.currentLocale)
)?.data as unknown as PersonType;

let founder = overrideObjects({ ...founderData }, Astro.props.content) as PersonType;
let coFounder = coFounderData as PersonType;

if (!founder?.enable) return;
---

<section class="section-spacing-vertical relative overflow-hidden">

  <div class="container">
    <div class="mx-auto max-w-5xl">
      <div class="mb-10 text-center" data-aos="fade-up" data-aos-duration="500">
        <span class="bg-primary/10 text-primary mb-3 inline-block rounded-full px-4 py-1.5 text-sm font-semibold tracking-wide uppercase">
          The People Behind Setu
        </span>
        <h2 class="text-h3-sm lg:text-h3 font-bold">Built by people who've lived it</h2>
      </div>

      <div class="grid gap-6 md:grid-cols-2">
        <!-- Founder Card -->
        <div
          class="bg-theme-light flex flex-col gap-6 rounded-2xl p-8 md:p-10"
          data-aos="fade-up"
          data-aos-delay="0"
          data-aos-duration="600">
          <div class="flex items-center gap-5">
            <div class="shrink-0">
              {
                founder.photo ? (
                  <OptimizedImage
                    src={founder.photo}
                    alt={founder.photoAlt || founder.name || "Founder"}
                    width={100}
                    height={100}
                    class="size-20 rounded-full object-cover ring-4 ring-primary/20"
                  />
                ) : (
                  <div
                    class="bg-primary text-text-inverse flex size-20 items-center justify-center rounded-full text-2xl font-bold ring-4 ring-primary/20"
                    title="Photo coming soon">
                    {founder.initials || "MS"}
                  </div>
                )
              }
            </div>
            <div>
              {founder.name && <p class="text-lg font-bold">{founder.name}</p>}
              {founder.role && <p class="text-primary text-sm font-semibold">{founder.role}</p>}
              <span class="bg-secondary/15 text-secondary mt-1 inline-block rounded-full px-3 py-0.5 text-xs font-semibold">Ahmedabad, India</span>
            </div>
          </div>
          {
            founder.quote && (
              <p
                class="text-text-default/80 border-primary border-l-4 pl-4 text-base italic leading-relaxed"
                set:html={markdownify(`"${founder.quote}"`)}
              />
            )
          }
          {
            founder.bio && (
              <p
                class="text-text-default/60 text-sm leading-relaxed"
                set:html={markdownify(founder.bio)}
              />
            )
          }
        </div>

        <!-- Co-Founder Card -->
        {
          coFounder?.enable !== false && coFounder && (
            <div
              class="bg-theme-light flex flex-col gap-6 rounded-2xl p-8 md:p-10"
              data-aos="fade-up"
              data-aos-delay="150"
              data-aos-duration="600">
              <div class="flex items-center gap-5">
                <div class="shrink-0">
                  {
                    coFounder.photo ? (
                      <OptimizedImage
                        src={coFounder.photo}
                        alt={coFounder.photoAlt || coFounder.name || "Co-Founder"}
                        width={100}
                        height={100}
                        class="size-20 rounded-full object-cover ring-4 ring-secondary/20"
                      />
                    ) : (
                      <div
                        class="bg-secondary text-text-inverse flex size-20 items-center justify-center rounded-full text-2xl font-bold ring-4 ring-secondary/20"
                        title="Photo coming soon">
                        {coFounder.initials || "MG"}
                      </div>
                    )
                  }
                </div>
                <div>
                  {coFounder.name && <p class="text-lg font-bold">{coFounder.name}</p>}
                  {coFounder.role && <p class="text-secondary text-sm font-semibold">{coFounder.role}</p>}
                  <span class="bg-primary/10 text-primary mt-1 inline-block rounded-full px-3 py-0.5 text-xs font-semibold">Germany — 14 Years</span>
                </div>
              </div>
              {
                coFounder.quote && (
                  <p
                    class="text-text-default/80 border-secondary border-l-4 pl-4 text-base italic leading-relaxed"
                    set:html={markdownify(`"${coFounder.quote}"`)}
                  />
                )
              }
              {
                coFounder.bio && (
                  <p
                    class="text-text-default/60 text-sm leading-relaxed"
                    set:html={markdownify(coFounder.bio)}
                  />
                )
              }
            </div>
          )
        }
      </div>
    </div>
  </div>
</section>
