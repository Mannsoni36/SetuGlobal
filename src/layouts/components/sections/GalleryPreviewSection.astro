---
const photos = [
  { src: "/images/gallery/cities/berlin.jpg", label: "Berlin", sub: "Capital of Germany" },
  { src: "/images/gallery/cities/munich.jpg", label: "Munich", sub: "Bavaria's Crown Jewel" },
  { src: "/images/gallery/culture/neuschwanstein.jpg", label: "Neuschwanstein", sub: "Iconic Castle" },
  { src: "/images/gallery/student-life/campus.jpg", label: "Campus Life", sub: "Student Community" },
  { src: "/images/gallery/cities/hamburg.jpg", label: "Hamburg", sub: "Port City Vibes" },
  { src: "/images/gallery/culture/oktoberfest.jpg", label: "Oktoberfest", sub: "German Culture" },
  { src: "/images/gallery/universities/tu-munich.jpg", label: "TU Munich", sub: "World-Class University" },
  { src: "/images/gallery/student-life/international.jpg", label: "Student Life", sub: "International Community" },
];
---

<section class="section-spacing-vertical bg-[#f5f3ef] overflow-hidden">
  <div class="container">
    <div class="flex items-end justify-between mb-8" data-aos="fade-up" data-aos-duration="500">
      <div>
        <p class="text-primary mb-1 text-sm font-bold uppercase tracking-widest">Germany Awaits</p>
        <h2 class="text-3xl font-black lg:text-4xl">See it before you go</h2>
      </div>
      <a
        href="/gallery/"
        class="hidden sm:inline-flex items-center gap-2 text-sm font-bold text-primary hover:text-primary/70 transition-colors">
        View all photos
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
      </a>
    </div>

    <!-- Flip card grid -->
    <div class="grid grid-cols-2 gap-2 sm:grid-cols-4 sm:gap-3 lg:gap-4">

      <!-- First photo: tall, spans 2 rows -->
      <a
        href="/gallery/"
        class="col-span-1 row-span-2 flip-card block"
        style="min-height: 300px;"
        data-aos="fade-up" data-aos-duration="500">
        <div class="flip-card-inner h-full">
          <div class="flip-card-front rounded-2xl overflow-hidden">
            <img src={photos[0].src} alt={photos[0].label} loading="lazy" class="w-full h-full object-cover" />
            <div class="absolute bottom-0 inset-x-0 bg-gradient-to-t from-black/60 to-transparent p-4">
              <span class="text-white text-sm font-bold">{photos[0].label}</span>
            </div>
          </div>
          <div class="flip-card-back rounded-2xl bg-primary flex flex-col items-center justify-center gap-3 p-5">
            <span class="text-4xl">🇩🇪</span>
            <p class="text-white font-black text-lg text-center">{photos[0].label}</p>
            <p class="text-white/70 text-xs text-center">{photos[0].sub}</p>
            <span class="mt-2 text-white/60 text-xs font-semibold tracking-wide uppercase">View Gallery →</span>
          </div>
        </div>
      </a>

      <!-- Remaining 7 photos -->
      {photos.slice(1).map((photo, i) => (
        <a
          href="/gallery/"
          class="flip-card block aspect-[4/3]"
          data-aos="fade-up"
          data-aos-delay={(i % 4) * 60}
          data-aos-duration="500">
          <div class="flip-card-inner h-full">
            <div class="flip-card-front rounded-2xl overflow-hidden">
              <img src={photo.src} alt={photo.label} loading="lazy" class="w-full h-full object-cover" />
              <div class="absolute bottom-0 inset-x-0 bg-gradient-to-t from-black/60 to-transparent p-3">
                <span class="text-white text-xs font-bold">{photo.label}</span>
              </div>
            </div>
            <div class:list={[
              "flip-card-back rounded-2xl flex flex-col items-center justify-center gap-2 p-4",
              i % 2 === 0 ? "bg-primary" : "bg-secondary"
            ]}>
              <p class="text-white font-black text-sm text-center">{photo.label}</p>
              <p class="text-white/70 text-xs text-center">{photo.sub}</p>
              <span class="mt-1 text-white/60 text-xs font-semibold tracking-wide uppercase">View Gallery →</span>
            </div>
          </div>
        </a>
      ))}
    </div>

    <!-- Mobile view all -->
    <div class="mt-6 text-center sm:hidden">
      <a href="/gallery/" class="inline-flex items-center gap-2 text-sm font-bold text-primary hover:text-primary/70 transition-colors">
        View all photos →
      </a>
    </div>
  </div>
</section>

<style>
  .flip-card {
    perspective: 1000px;
    position: relative;
  }

  .flip-card-inner {
    position: relative;
    width: 100%;
    transition: transform 0.55s cubic-bezier(0.4, 0, 0.2, 1);
    transform-style: preserve-3d;
  }

  .flip-card:hover .flip-card-inner {
    transform: rotateY(180deg);
  }

  .flip-card-front,
  .flip-card-back {
    position: absolute;
    inset: 0;
    backface-visibility: hidden;
    -webkit-backface-visibility: hidden;
  }

  .flip-card-back {
    transform: rotateY(180deg);
  }

  /* cursor pointer already handled by <a> tag */
</style>
