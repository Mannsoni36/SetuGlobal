---
import type { Section } from "@/types";
import ContactForm from "../widgets/ContactForm.astro";
import { getEntryCTM } from "@/lib/contentParser.astro";
import overrideObjects from "@/lib/utils/overrideObjects.ts";
import type { contactSectionSchema } from "@/sections.schema";
import type { z } from "astro/zod";
import OptimizedImage from "../utilities/OptimizedImage.astro";
import SectionTitle from "../global/SectionTitle.astro";

type ContactSection = Section & z.infer<typeof contactSectionSchema>;

type Props = {
  content?: ContactSection;
  hasSectionSpacing?: boolean;
};

let defaultContent = (
  await getEntryCTM("sections", "contact-section", Astro.currentLocale)
)?.data as ContactSection;

let actualContent = overrideObjects(
  { ...defaultContent },
  Astro.props.content,
) as ContactSection;

let {
  enable = true,
  title,
  form,
  image,
  imageAlt,
  badge,
} = actualContent;

if (!enable) return null;
const { hasSectionSpacing = true } = Astro.props;
---

<section
  id="contact"
  class:list={["overflow-hidden scroll-mt-28", { "pt-0": !hasSectionSpacing }]}
>
  <div class="bg-theme-light relative">
    <div class="container grid grid-cols-1 items-stretch lg:grid-cols-2 lg:gap-16 xl:gap-24">

      <!-- Left: image -->
      <div
        class="order-2 lg:order-1 overflow-hidden rounded-2xl my-10 lg:my-16"
        data-aos="fade-right"
        data-aos-duration="700">
        {image && (
          <OptimizedImage
            src={image}
            alt={imageAlt || "Contact"}
            width={640}
            height={700}
            class="size-full object-cover rounded-2xl"
          />
        )}
      </div>

      <!-- Right: form panel -->
      <div
        class="order-1 lg:order-2 section-spacing-vertical flex flex-col justify-center gap-8"
        data-aos="fade-left"
        data-aos-duration="700">

        {badge && (
          <span class="bg-primary/10 text-primary inline-block self-start rounded-full px-4 py-1.5 text-sm font-semibold uppercase tracking-wide">
            {badge}
          </span>
        )}

        {title && <SectionTitle title={title} />}

        <!-- Quick contact strip -->
        <div class="flex flex-wrap gap-4">
          <a
            href="https://wa.me/918140881823"
            target="_blank"
            rel="noopener noreferrer"
            class="bg-secondary/10 text-secondary hover:bg-secondary hover:text-white flex items-center gap-2 rounded-full px-5 py-2.5 text-sm font-semibold transition-colors duration-200">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            WhatsApp
          </a>
          <a
            href="tel:+918140881823"
            class="bg-primary/10 text-primary hover:bg-primary hover:text-white flex items-center gap-2 rounded-full px-5 py-2.5 text-sm font-semibold transition-colors duration-200">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.77 13a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.68 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 9.91a16 16 0 0 0 6.72 6.72l1.28-1.28a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"></path></svg>
            Call Us
          </a>
        </div>

        {form && <ContactForm form={form} />}
      </div>
    </div>
  </div>
</section>
