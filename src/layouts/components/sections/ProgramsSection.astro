---
import { getEntryCTM } from "@/lib/contentParser.astro";
import overrideObjects from "@/lib/utils/overrideObjects";
import { markdownify } from "@/lib/utils/textConverter";
import SectionBadge from "../global/SectionBadge.astro";
import Icons from "@/helpers/Icons.astro";

type Program = { icon?: string; name: string };
type SectionType = {
  enable?: boolean;
  badge?: string;
  title?: string;
  description?: string;
  programs?: Program[];
  note?: string;
};

type Props = { content?: SectionType };

let defaultContent = (
  await getEntryCTM("sections", "programs", Astro.currentLocale)
)?.data as unknown as SectionType;

let actualContent = overrideObjects(
  { ...defaultContent },
  Astro.props.content,
) as SectionType;

const { enable = true, badge, title, description, programs, note } =
  actualContent ?? {};

if (!enable) return;

// Split into two rows for staggered display
const half = Math.ceil((programs?.length ?? 0) / 2);
const firstRow = programs?.slice(0, half) ?? [];
const secondRow = programs?.slice(half) ?? [];

const stats = [
  { value: "400+", label: "English-taught programs" },
  { value: "100+", label: "Disciplines covered" },
  { value: "Low", label: "Fees vs UK/US/Australia" },
];
---

<section id="programs" class="section-spacing-vertical relative scroll-mt-28 overflow-hidden">

  <!-- Subtle background pattern -->
  <div class="pointer-events-none absolute inset-0 -z-10">
    <div class="absolute top-0 left-1/2 h-px w-3/4 -translate-x-1/2 bg-gradient-to-r from-transparent via-primary/20 to-transparent"></div>
    <div class="absolute bottom-0 left-1/2 h-px w-3/4 -translate-x-1/2 bg-gradient-to-r from-transparent via-secondary/20 to-transparent"></div>
  </div>

  <div class="container">

    <!-- Header -->
    <div class="mx-auto max-w-3xl text-center" data-aos="fade-up" data-aos-duration="500">
      {badge && <SectionBadge title={badge} />}
      {title && (
        <h2 class="text-h2-sm lg:text-h2 mb-2 font-bold">{title}</h2>
      )}
      {description && (
        <p class="text-text-default/60 text-base xl:text-lg mb-4" set:html={markdownify(description)} />
      )}
      <!-- Curiosity hook -->
      <p class="text-primary text-sm font-semibold uppercase tracking-widest">
        → Which one is yours?
      </p>
    </div>

    <!-- Stat strip -->
    <div class="mt-10 flex flex-wrap justify-center gap-6" data-aos="fade-up" data-aos-delay="100" data-aos-duration="500">
      {stats.map((s) => (
        <div class="flex flex-col items-center gap-1">
          <span class="text-primary text-3xl font-black">{s.value}</span>
          <span class="text-text-default/50 text-xs font-medium uppercase tracking-wide">{s.label}</span>
        </div>
      ))}
    </div>

    <!-- Programs grid — two staggered rows -->
    {programs && programs.length > 0 && (
      <div class="mt-10 space-y-4">
        <!-- Row 1 -->
        <div
          class="flex flex-wrap justify-center gap-3"
          data-aos="fade-up"
          data-aos-delay="150"
          data-aos-duration="600">
          {firstRow.map((program) => (
            <div class="group bg-theme-light hover:bg-primary border-border-dark/10 flex cursor-default items-center gap-2.5 rounded-full border px-5 py-3 transition-all duration-250 hover:border-transparent hover:shadow-md">
              {program.icon && (
                <span class="text-primary group-hover:text-white transition-colors duration-250">
                  <Icons icon={program.icon} width="18" height="18" />
                </span>
              )}
              <span class="text-sm font-semibold group-hover:text-white transition-colors duration-250 lg:text-base">
                {program.name}
              </span>
            </div>
          ))}
        </div>
        <!-- Row 2 -->
        <div
          class="flex flex-wrap justify-center gap-3"
          data-aos="fade-up"
          data-aos-delay="250"
          data-aos-duration="600">
          {secondRow.map((program) => (
            <div class="group bg-theme-light hover:bg-secondary border-border-dark/10 flex cursor-default items-center gap-2.5 rounded-full border px-5 py-3 transition-all duration-250 hover:border-transparent hover:shadow-md">
              {program.icon && (
                <span class="text-secondary group-hover:text-white transition-colors duration-250">
                  <Icons icon={program.icon} width="18" height="18" />
                </span>
              )}
              <span class="text-sm font-semibold group-hover:text-white transition-colors duration-250 lg:text-base">
                {program.name}
              </span>
            </div>
          ))}
        </div>
      </div>
    )}

    <!-- Note / CTA -->
    {note && (
      <div
        class="mt-10 mx-auto max-w-xl rounded-2xl bg-gradient-to-r from-primary/10 to-secondary/10 px-8 py-5 text-center"
        data-aos="fade-up"
        data-aos-delay="300"
        data-aos-duration="500">
        <p
          class="text-text-default/80 text-sm font-medium xl:text-base [&_a]:text-primary [&_a]:font-bold [&_a]:underline-offset-2 [&_a]:hover:underline"
          set:html={markdownify(note)}
        />
      </div>
    )}
  </div>
</section>
