---
import { getEntryCTM } from "@/lib/contentParser.astro";
import overrideObjects from "@/lib/utils/overrideObjects";
import { markdownify } from "@/lib/utils/textConverter";
import SectionBadge from "../global/SectionBadge.astro";
import SectionTitle from "../global/SectionTitle.astro";
import Icons from "@/helpers/Icons.astro";

type Program = { icon?: string; name: string };
type SectionType = {
  enable?: boolean;
  badge?: string;
  title?: string;
  description?: string;
  programs?: Program[];
  note?: string;
};

type Props = { content?: SectionType };

let defaultContent = (
  await getEntryCTM("sections", "programs", Astro.currentLocale)
)?.data as unknown as SectionType;

let actualContent = overrideObjects(
  { ...defaultContent },
  Astro.props.content,
) as SectionType;

const { enable = true, badge, title, description, programs, note } =
  actualContent ?? {};

if (!enable) return;
---

<section id="programs" class="section-spacing-vertical relative scroll-mt-28">
  <div class="container">
    <div class="mx-auto max-w-2xl text-center">
      {badge && <SectionBadge title={badge} />}
      {title && <SectionTitle title={title} class="mb-4!" />}
      {
        description && (
          <p
            class="text-text-default/70 text-base xl:text-lg"
            set:html={markdownify(description)}
          />
        )
      }
    </div>

    {
      programs && programs.length > 0 && (
        <div
          class="mt-10 flex flex-wrap justify-center gap-3"
          data-aos="fade-up"
          data-aos-duration="600">
          {programs.map((program) => (
            <div class="bg-theme-light border-border-dark/10 flex items-center gap-2.5 rounded-full border px-5 py-2.5">
              {program.icon && (
                <span class="text-primary">
                  <Icons icon={program.icon} width="18" height="18" />
                </span>
              )}
              <span class="text-sm font-medium lg:text-base">{program.name}</span>
            </div>
          ))}
        </div>
      )
    }

    {
      note && (
        <p
          class="mt-8 text-center text-sm xl:text-base"
          set:html={markdownify(note)}
        />
      )
    }
  </div>
</section>
