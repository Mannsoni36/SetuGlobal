---
import social from "@/config/social.json";
import type { NavigationLink } from "@/types";
import { markdownify } from "@/lib/utils/textConverter";
import config from ".astro/config.generated.json";
import { useTranslations, getLocaleUrlCTM } from "@/lib/utils/i18nUtils";
import Button from "../Button.astro";
import { filteredEnabled } from "@/lib/utils/filteredEnabled";

const t = await useTranslations(Astro.currentLocale as string);
let footerMenus = t("footer") as {
  label: string;
  list: NavigationLink[];
  footerOuterSpace?: boolean;
}[];

let { copyright, footerDescription } = config.settings;

footerDescription = footerDescription || t("footerBlock.description");
const copyrightText = copyright.text;

const stats = [
  { value: "14", label: "Years in Germany" },
  { value: "8+", label: "Services Offered" },
  { value: "100%", label: "Free Consultation" },
  { value: "€0", label: "Consultation Fee" },
];
---

<footer>
  <!-- Pre-footer CTA band -->
  <div class="bg-primary">
    <div class="container flex flex-col items-center justify-between gap-6 py-10 text-center md:flex-row md:text-left">
      <div>
        <p class="text-xl font-bold text-white md:text-2xl">Ready to study in Germany?</p>
        <p class="mt-1 text-sm text-white/70">Book your free consultation — no fees, no commitment.</p>
      </div>
      <div class="flex flex-col gap-3 sm:flex-row">
        <a
          href="/#contact"
          class="rounded-lg bg-white px-7 py-3 text-sm font-bold text-primary transition-opacity hover:opacity-90">
          Book Free Consultation
        </a>
        <a
          href={`https://wa.me/${config.contact.phone?.replace(/\s|\+/g, "")}`}
          target="_blank"
          rel="noopener noreferrer"
          class="rounded-lg border-2 border-white/40 px-7 py-3 text-sm font-bold text-white transition-colors hover:bg-white/10">
          🇮🇳 WhatsApp India
        </a>
        <a
          href={`https://wa.me/${(config.contact as any).phoneGermany?.replace(/\s|\+/g, "")}`}
          target="_blank"
          rel="noopener noreferrer"
          class="rounded-lg border-2 border-white/40 px-7 py-3 text-sm font-bold text-white transition-colors hover:bg-white/10">
          🇩🇪 WhatsApp Germany
        </a>
      </div>
    </div>
  </div>

  <!-- Stats strip -->
  <div class="bg-secondary">
    <div class="container">
      <div class="flex flex-wrap items-center justify-around gap-6 py-6">
        {stats.map((s) => (
          <div class="flex flex-col items-center gap-0.5">
            <span class="text-2xl font-black text-white">{s.value}</span>
            <span class="text-xs font-semibold uppercase tracking-wider text-white/70">{s.label}</span>
          </div>
        ))}
      </div>
    </div>
  </div>

  <!-- Main footer body — cream/beige -->
  <div class="bg-[#f5f3ef]">
    <div class="relative container flex flex-col">
      <div
        class="grid gap-12 py-15 md:grid-cols-6 md:py-20 lg:flex lg:justify-between xl:py-27">
        <div class="space-y-4 md:col-span-3">
          <h3 class="text-text-default mb-4 text-2xl font-semibold capitalize md:mb-10">
            {t("footerBlock.aboutUsLabel")}
          </h3>
          {
            footerDescription && (
              <p
                class="text-text-default/60 max-w-74.5"
                set:html={markdownify(footerDescription)}
              />
            )
          }
          <div class="mt-6 flex flex-col gap-2 text-sm">
            <a
              href={`mailto:${config.contact.email}`}
              class="text-secondary hover:text-secondary/80 font-semibold transition-colors">
              {config.contact.email}
            </a>
            <a
              href={`tel:${config.contact.phone?.replace(/\s/g, "")}`}
              class="text-text-default/60 hover:text-text-default font-medium transition-colors">
              🇮🇳 {config.contact.phone}
            </a>
            <a
              href={`tel:${(config.contact as any).phoneGermany?.replace(/\s/g, "")}`}
              class="text-text-default/60 hover:text-text-default font-medium transition-colors">
              🇩🇪 {(config.contact as any).phoneGermany}
            </a>
            <p class="text-text-default/40 text-xs mt-1">Mon – Sat · 10:00 AM – 7:00 PM IST</p>
          </div>
        </div>

        <div class="md:col-span-3">
          <h3 class="text-text-default mb-4 text-2xl font-semibold capitalize md:mb-10">
            {t("footerBlock.officeLabel")}
          </h3>
          <div class="text-text-default/60 flex flex-col gap-4">
            <div class="flex gap-2">
              <span class="font-bold text-primary shrink-0">IN</span>
              <p class="leading-relaxed text-sm">{config.contact.location}</p>
            </div>
            <div class="flex gap-2">
              <span class="font-bold text-secondary shrink-0">DE</span>
              <p class="leading-relaxed text-sm">{(config.contact as any).locationGermany}</p>
            </div>
          </div>
        </div>

        {
          footerMenus?.map((menu) => (
            <div class="md:col-span-2">
              {menu.label && (
                <h3
                  class="text-text-default mb-4 text-2xl font-semibold capitalize md:mb-10"
                  set:html={markdownify(menu.label)}
                />
              )}
              <ul class="flex flex-col gap-3.5">
                {menu.list?.map((item) => (
                  <li>
                    <Button
                      tag="a"
                      variant="text"
                      url={getLocaleUrlCTM(item.url as string, Astro.currentLocale)}
                      label={item.name}
                      class="text-text-default/50 hover:text-primary transition-colors"
                    />
                  </li>
                ))}
              </ul>
            </div>
          ))
        }

        <div class="md:col-span-2">
          <h3 class="text-text-default mb-4 text-2xl font-semibold capitalize md:mb-10">
            {t("footerBlock.socialLabel")}
          </h3>
          <ul class="flex flex-col gap-3.5">
            {
              filteredEnabled(social.main).map((item: any) => (
                <li>
                  <Button
                    tag="a"
                    variant="text"
                    url={getLocaleUrlCTM(item.url as string, Astro.currentLocale)}
                    aria-label={item.label}
                    label={item.label}
                    class="text-text-default/50 hover:text-primary capitalize transition-colors"
                  />
                </li>
              ))
            }
          </ul>
        </div>
      </div>

      <!-- Bottom bar -->
      <div class="border-border-light flex flex-col items-center justify-center gap-1 border-t py-6">
        <p class="text-text-default/30 text-xs text-center">
          Setu Global Solution · Ahmedabad, Gujarat, India · Dedicated Germany Education Consultancy
        </p>
        <p class="text-text-default/25 text-xs text-center">
          © {new Date().getFullYear()} Setu Global Solution. All rights reserved.
        </p>
      </div>
    </div>
  </div>
</footer>
