---
import Base from "@/layouts/Base.astro";
import { generatePaths } from "@/lib/utils/i18nUtils";
import PageHeader from "@/components/widgets/PageHeader.astro";

export function getStaticPaths() {
  return generatePaths();
}

const photos = [
  // Cities
  {
    category: "Cities",
    title: "Berlin",
    subtitle: "The Creative Capital",
    description: "Home to world-class universities like Humboldt, TU Berlin & FU Berlin. A city that never stops inspiring.",
    color: "bg-primary",
    img: "/images/gallery/cities/berlin.jpg",
  },
  {
    category: "Cities",
    title: "Munich",
    subtitle: "Technology & Tradition",
    description: "Bavaria's gem — home to TU Munich, one of Europe's top engineering universities and BMW, Siemens HQ.",
    color: "bg-secondary",
    img: "/images/gallery/cities/munich.jpg",
  },
  {
    category: "Cities",
    title: "Hamburg",
    subtitle: "The Port City",
    description: "Germany's second largest city. A thriving student scene, world-famous harbour, and strong job market.",
    color: "bg-primary",
    img: "/images/gallery/cities/hamburg.jpg",
  },
  {
    category: "Cities",
    title: "Frankfurt",
    subtitle: "Finance & Future",
    description: "Europe's financial hub. Goethe University and a dense industry network make this a hotspot for graduates.",
    color: "bg-secondary",
    img: "/images/gallery/cities/frankfurt.jpg",
  },
  {
    category: "Cities",
    title: "Heidelberg",
    subtitle: "Germany's Oxford",
    description: "Heidelberg University — founded in 1386, it's Germany's oldest and one of its most beautiful campuses.",
    color: "bg-primary",
    img: "/images/gallery/cities/heidelberg.jpg",
  },
  {
    category: "Cities",
    title: "Cologne",
    subtitle: "Culture by the Rhine",
    description: "A student-friendly city with a vibrant arts scene, iconic cathedral, and top-ranked University of Cologne.",
    color: "bg-secondary",
    img: "/images/gallery/cities/cologne.jpg",
  },
  {
    category: "Cities",
    title: "Stuttgart",
    subtitle: "Automotive Capital",
    description: "Home to Mercedes-Benz and Porsche HQ. Engineering and business students thrive here with unbeatable industry connections.",
    color: "bg-primary",
    img: "/images/gallery/cities/stuttgart.jpg",
  },

  // Universities
  {
    category: "Universities",
    title: "TU Munich",
    subtitle: "Ranked #1 in Germany",
    description: "Consistently ranked Germany's top technical university. Excellent for engineering, CS, and natural sciences.",
    color: "bg-secondary",
    img: "/images/gallery/universities/tu-munich.jpg",
  },
  {
    category: "Universities",
    title: "RWTH Aachen",
    subtitle: "Engineering Excellence",
    description: "One of Europe's leading engineering universities — a top choice for Mechanical, Civil, and Electrical Engineering.",
    color: "bg-primary",
    img: "/images/gallery/universities/rwth-aachen.jpg",
  },
  {
    category: "Universities",
    title: "Heidelberg University",
    subtitle: "Est. 1386",
    description: "Germany's oldest university — a prestigious name in medicine, life sciences, and humanities.",
    color: "bg-secondary",
    img: "/images/gallery/universities/heidelberg-university.jpg",
  },
  {
    category: "Universities",
    title: "Humboldt University",
    subtitle: "Berlin's Finest",
    description: "29 Nobel Prize winners studied or taught here. Strong in law, social sciences, and natural sciences.",
    color: "bg-primary",
    img: "/images/gallery/universities/humboldt-berlin.jpg",
  },

  // Culture
  {
    category: "Culture",
    title: "Oktoberfest",
    subtitle: "Munich · Every October",
    description: "The world's largest folk festival. As a student in Munich, this is your first true German cultural experience.",
    color: "bg-secondary",
    img: "/images/gallery/culture/oktoberfest.jpg",
  },
  {
    category: "Culture",
    title: "Christmas Markets",
    subtitle: "December Magic",
    description: "Iconic Weihnachtsmärkte across every German city. Glühwein, gingerbread, and an atmosphere like nowhere else.",
    color: "bg-primary",
    img: "/images/gallery/culture/christmas-markets.jpg",
  },
  {
    category: "Culture",
    title: "Neuschwanstein Castle",
    subtitle: "Bavaria's Crown Jewel",
    description: "The fairy-tale castle that inspired Disney. A weekend trip from Munich that you'll remember for a lifetime.",
    color: "bg-secondary",
    img: "/images/gallery/culture/neuschwanstein.jpg",
  },
  {
    category: "Culture",
    title: "Rhine Valley",
    subtitle: "UNESCO Heritage",
    description: "Vineyards, medieval castles, and the legendary Lorelei rock. Germany's most scenic river journey.",
    color: "bg-primary",
    img: "/images/gallery/culture/rhine-valley.jpg",
  },

  // Student Life
  {
    category: "Student Life",
    title: "Campus Life",
    subtitle: "Study. Connect. Grow.",
    description: "German campuses are vibrant, modern, and deeply international. You'll never feel like an outsider.",
    color: "bg-primary",
    img: "/images/gallery/student-life/campus.jpg",
  },
  {
    category: "Student Life",
    title: "Cycling Culture",
    subtitle: "The Student Way",
    description: "Germans cycle everywhere — it's cheap, fast, and eco-friendly. Your bike becomes your best friend on campus.",
    color: "bg-secondary",
    img: "/images/gallery/student-life/cycling.jpg",
  },
  {
    category: "Student Life",
    title: "International Community",
    subtitle: "200+ Nationalities",
    description: "Germany is one of the world's top destinations for international students. You'll build a global network here.",
    color: "bg-primary",
    img: "/images/gallery/student-life/international.jpg",
  },
  {
    category: "Student Life",
    title: "Mensa & Student Life",
    subtitle: "Affordable. Social. Fun.",
    description: "The German 'Mensa' (student cafeteria) serves hot meals for under €3. Community spirit at its best.",
    color: "bg-secondary",
    img: "/images/gallery/student-life/mensa.jpg",
  },
  {
    category: "Student Life",
    title: "University Libraries",
    subtitle: "World-Class Resources",
    description: "German university libraries are open late, free to use, and stocked with everything you need to excel in your studies.",
    color: "bg-primary",
    img: "/images/gallery/student-life/library.jpg",
  },
];

const categories = ["All", "Cities", "Universities", "Culture", "Student Life"];
---

<Base
  title="Gallery — Germany Life, Cities & Universities | Setu Global Solution"
  metaDescription="Explore Germany through our gallery — iconic cities, top universities, vibrant culture, and student life. See what awaits you with Setu Global Solution.">

  <PageHeader
    title="Life in Germany"
    breadcrumbTitle="Gallery"
  />

  <section class="section-spacing-vertical bg-[#f5f3ef]">
    <div class="container">

      <!-- Intro -->
      <div class="mx-auto mb-12 max-w-2xl text-center" data-aos="fade-up" data-aos-duration="500">
        <p class="text-primary mb-2 text-sm font-bold uppercase tracking-widest">Flip each card to explore</p>
        <h2 class="text-3xl font-black lg:text-4xl mb-3">See Germany before you go</h2>
        <p class="text-text-default/60 text-base">
          Cities, universities, culture and student life — hover over any card to discover more.
        </p>
      </div>

      <!-- Category filter tabs -->
      <div class="flex flex-wrap justify-center gap-2 mb-10" id="gallery-filters">
        {categories.map((cat) => (
          <button
            data-filter={cat}
            class:list={[
              "filter-btn rounded-full px-5 py-2 text-sm font-semibold transition-all duration-200 border",
              cat === "All"
                ? "bg-primary text-white border-primary"
                : "bg-white text-text-default/60 border-border-light hover:border-primary hover:text-primary"
            ]}>
            {cat}
          </button>
        ))}
      </div>

      <!-- Flip card grid -->
      <div class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4" id="gallery-grid">
        {photos.map((photo, i) => (
          <div
            class="flip-card-wrap"
            data-category={photo.category}
            data-aos="fade-up"
            data-aos-delay={Math.min((i % 4) * 80, 240)}
            data-aos-duration="500"
            style="height: 320px;">
            <div class="flip-card-inner w-full h-full relative" style="transform-style: preserve-3d; transition: transform 0.65s cubic-bezier(0.23, 1, 0.32, 1);">

              <!-- Front -->
              <div class="flip-card-front absolute inset-0 rounded-2xl overflow-hidden shadow-md" style="backface-visibility: hidden;">
                <img
                  src={photo.img}
                  alt={photo.title}
                  loading="lazy"
                  class="w-full h-full object-cover"
                />
                <!-- Gradient overlay -->
                <div class="absolute inset-0 bg-gradient-to-t from-black/70 via-black/10 to-transparent"></div>
                <!-- Category pill -->
                <span class:list={[
                  "absolute top-4 left-4 text-xs font-bold uppercase tracking-wider text-white px-3 py-1 rounded-full",
                  photo.color + "/80"
                ]}>
                  {photo.category}
                </span>
                <!-- Title -->
                <div class="absolute bottom-0 left-0 right-0 p-5">
                  <h3 class="text-white text-xl font-black leading-tight">{photo.title}</h3>
                  <p class="text-white/70 text-sm mt-0.5">{photo.subtitle}</p>
                </div>
                <!-- Flip hint -->
                <div class="absolute top-4 right-4 bg-white/20 backdrop-blur-sm rounded-full p-1.5">
                  <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 2v6h-6"/><path d="M3 12a9 9 0 0 1 15-6.7L21 8"/><path d="M3 22v-6h6"/><path d="M21 12a9 9 0 0 1-15 6.7L3 16"/></svg>
                </div>
              </div>

              <!-- Back -->
              <div
                class:list={["flip-card-back absolute inset-0 rounded-2xl flex flex-col justify-between p-6 text-white", photo.color]}
                style="backface-visibility: hidden; transform: rotateY(180deg);">
                <div>
                  <span class="text-white/60 text-xs font-bold uppercase tracking-widest">{photo.category}</span>
                  <h3 class="text-2xl font-black mt-2 leading-tight">{photo.title}</h3>
                  <p class="text-white/60 text-sm mt-0.5 font-semibold">{photo.subtitle}</p>
                </div>
                <p class="text-white/85 text-sm leading-relaxed">{photo.description}</p>
                <a
                  href="/#contact"
                  class="inline-block bg-white/20 hover:bg-white/30 transition-colors text-white text-xs font-bold uppercase tracking-wide px-4 py-2 rounded-full self-start">
                  Ask us about Germany →
                </a>
              </div>

            </div>
          </div>
        ))}
      </div>

      <!-- CTA -->
      <div class="mt-14 text-center" data-aos="fade-up" data-aos-duration="400">
        <p class="text-text-default/50 text-sm mb-4">Ready to be part of this story?</p>
        <a
          href="/#contact"
          class="inline-block bg-primary hover:bg-primary/90 text-white font-bold px-8 py-4 rounded-xl transition-colors duration-200">
          Book a Free Consultation
        </a>
      </div>

    </div>
  </section>

</Base>

<style>
  .flip-card-wrap {
    perspective: 1200px;
    cursor: pointer;
  }
  .flip-card-wrap:hover .flip-card-inner {
    transform: rotateY(180deg);
  }
</style>

<script>
  const filterBtns = document.querySelectorAll<HTMLButtonElement>(".filter-btn");
  const cards = document.querySelectorAll<HTMLElement>(".flip-card-wrap");

  filterBtns.forEach((btn) => {
    btn.addEventListener("click", () => {
      const filter = btn.dataset.filter;

      filterBtns.forEach((b) => {
        b.classList.remove("bg-primary", "text-white", "border-primary");
        b.classList.add("bg-white", "text-text-default/60", "border-border-light");
      });
      btn.classList.add("bg-primary", "text-white", "border-primary");
      btn.classList.remove("bg-white", "text-text-default/60", "border-border-light");

      cards.forEach((card) => {
        const show = filter === "All" || card.dataset.category === filter;
        card.style.display = show ? "block" : "none";
      });
    });
  });
</script>
