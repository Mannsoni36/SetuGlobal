---
import Base from "@/layouts/Base.astro";
import { generatePaths } from "@/lib/utils/i18nUtils";
import PageHeader from "@/components/widgets/PageHeader.astro";
import OptimizedImage from "@/components/utilities/OptimizedImage.astro";

export function getStaticPaths() {
  return generatePaths();
}

const categories = [
  {
    label: "Germany Cities",
    tag: "cities",
    photos: [
      { src: "/images/gallery/cities/berlin.jpg", alt: "Brandenburg Gate, Berlin", caption: "Berlin" },
      { src: "/images/gallery/cities/munich.jpg", alt: "Marienplatz, Munich", caption: "Munich" },
      { src: "/images/gallery/cities/hamburg.jpg", alt: "Speicherstadt, Hamburg", caption: "Hamburg" },
      { src: "/images/gallery/cities/frankfurt.jpg", alt: "Frankfurt skyline", caption: "Frankfurt" },
      { src: "/images/gallery/cities/heidelberg.jpg", alt: "Heidelberg castle and river", caption: "Heidelberg" },
      { src: "/images/gallery/cities/cologne.jpg", alt: "Cologne Cathedral", caption: "Cologne" },
    ],
  },
  {
    label: "Student Life",
    tag: "student-life",
    photos: [
      { src: "/images/gallery/student-life/campus1.jpg", alt: "Students studying on campus in Germany", caption: "Campus Life" },
      { src: "/images/gallery/student-life/library.jpg", alt: "University library in Germany", caption: "University Library" },
      { src: "/images/gallery/student-life/cafeteria.jpg", alt: "Students in university cafeteria", caption: "Mensa (Cafeteria)" },
      { src: "/images/gallery/student-life/festival.jpg", alt: "Students at a German city festival", caption: "City Festivals" },
      { src: "/images/gallery/student-life/cycling.jpg", alt: "Students cycling in a German city", caption: "Cycling Culture" },
      { src: "/images/gallery/student-life/group.jpg", alt: "International student group in Germany", caption: "International Community" },
    ],
  },
  {
    label: "Universities",
    tag: "universities",
    photos: [
      { src: "/images/gallery/universities/tu-munich.jpg", alt: "TU Munich campus", caption: "TU Munich" },
      { src: "/images/gallery/universities/rwth.jpg", alt: "RWTH Aachen campus", caption: "RWTH Aachen" },
      { src: "/images/gallery/universities/heidelberg-uni.jpg", alt: "Heidelberg University", caption: "Heidelberg University" },
      { src: "/images/gallery/universities/hu-berlin.jpg", alt: "Humboldt University Berlin", caption: "Humboldt University" },
    ],
  },
];
---

<Base
  title="Gallery — Germany Life & Student Experiences"
  metaDescription="Photos of Germany cities, student life, top universities, and our team on the ground in Germany. See what awaits you with Setu Global Solution.">

  <PageHeader
    title="Gallery"
    breadcrumbTitle="Gallery"
  />

  <section class="section-spacing-vertical">
    <div class="container">

      <!-- Intro -->
      <div class="mx-auto mb-14 max-w-2xl text-center" data-aos="fade-up" data-aos-duration="500">
        <p class="text-primary mb-2 text-sm font-bold uppercase tracking-widest">See It Before You Go</p>
        <h2 class="text-h3-sm lg:text-h3 mb-4 font-bold">Life in Germany — through our lens</h2>
        <p class="text-text-default/60 text-base lg:text-lg">
          From historic city centres to vibrant student campuses — here's a glimpse of the world waiting for you.
        </p>
      </div>

      <!-- Category blocks -->
      {categories.map((category, ci) => (
        <div class="mb-16 last:mb-0" data-aos="fade-up" data-aos-delay={ci * 50} data-aos-duration="500">
          <!-- Category label -->
          <div class="mb-6 flex items-center gap-4">
            <h3 class="text-h5-sm lg:text-h5 font-bold">{category.label}</h3>
            <div class="h-px flex-1 bg-border-light"></div>
          </div>

          <!-- Photo grid -->
          <div class="grid grid-cols-2 gap-3 sm:grid-cols-3 lg:grid-cols-4 xl:gap-4">
            {category.photos.map((photo, pi) => (
              <div
                class="group relative overflow-hidden rounded-xl bg-theme-light aspect-[4/3]"
                data-aos="fade-up"
                data-aos-delay={pi * 60}
                data-aos-duration="400">
                <img
                  src={photo.src}
                  alt={photo.alt}
                  loading="lazy"
                  class="size-full object-cover transition-transform duration-500 group-hover:scale-105"
                  onerror="this.parentElement.classList.add('photo-missing')"
                />
                <!-- Caption overlay -->
                <div class="absolute inset-x-0 bottom-0 translate-y-full bg-gradient-to-t from-black/70 to-transparent px-4 py-3 transition-transform duration-300 group-hover:translate-y-0">
                  <p class="text-xs font-semibold text-white">{photo.caption}</p>
                </div>
              </div>
            ))}
          </div>
        </div>
      ))}

      <!-- Add photos notice -->
      <div class="mt-12 rounded-2xl border border-dashed border-primary/30 bg-primary/5 px-8 py-10 text-center">
        <p class="text-primary mb-2 font-bold">More photos coming soon</p>
        <p class="text-text-default/60 text-sm">We're constantly updating this gallery with student stories, city tours, and campus life from Germany.</p>
        <a href="/#contact" class="mt-4 inline-block rounded-full bg-primary px-6 py-2.5 text-sm font-semibold text-white hover:bg-primary/90 transition-colors">
          Talk to our Germany expert →
        </a>
      </div>

    </div>
  </section>

</Base>

<style>
  .photo-missing {
    background: #f5f3ef;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .photo-missing img {
    display: none;
  }
  .photo-missing::after {
    content: "Photo coming soon";
    font-size: 0.75rem;
    color: #9ca3af;
    text-align: center;
    padding: 1rem;
  }
</style>
