---
const quickLinks = ['#home:Home', '#services:Services', '#process:How It Works', '#why-germany:Why Germany', '#programs:Programs', '#faq:FAQ', '#contact:Contact Us'];
const ourServices = ['Study Counselling', 'University Selection', 'SOP & Documentation', 'Visa Guidance', 'Scholarship Support', 'Blocked Account Help', 'Accommodation', 'Career Guidance'];
---
<footer>
  <div class="footer-grid">
    <div class="footer-brand">
      <div style="display: flex; align-items: center; gap: 10px;">
        <svg width="36" height="36" viewBox="0 0 80 80" fill="none">
          <circle cx="40" cy="28" r="22" fill="#FF8A00" />
          <path d="M15 48 Q30 20 40 28 Q50 36 65 48" stroke="#A87DEA" stroke-width="6" fill="none" stroke-linecap="round" />
          <path d="M10 54 Q25 38 40 44 Q55 50 70 38" stroke="#C8A8F0" stroke-width="4.5" fill="none" stroke-linecap="round" opacity="0.7" />
        </svg>
        <div class="logo-text" style="color: white;">Setu Global<span>Solution</span></div>
      </div>
      <p class="footer-tagline">Bridging Ahmedabad to Germany — your trusted partner for university admissions, visa, and career guidance in Germany.</p>
      <div class="social-links">
        <a href="#" class="social-link" title="LinkedIn">in</a>
        <a href="#" class="social-link" title="Instagram">📷</a>
        <a href="#" class="social-link" title="Facebook">f</a>
        <a href="#" class="social-link" title="YouTube">▶</a>
      </div>
    </div>

    <div class="footer-col">
      <h4>Quick Links</h4>
      <ul class="footer-links">
        {quickLinks.map(item => {
          const [href, label] = item.split(':');
          return <li><a href={href}>{label}</a></li>;
        })}
      </ul>
    </div>

    <div class="footer-col">
      <h4>Our Services</h4>
      <ul class="footer-links">
        {ourServices.map(s => (
          <li><a href="#services">{s}</a></li>
        ))}
      </ul>
    </div>

    <div class="footer-col">
      <h4>Contact Us</h4>
      <div class="footer-contact-item">
        <span class="fc-icon">📞</span>
        <a href="tel:+918140881823">+91 81408 81823</a>
      </div>
      <div class="footer-contact-item">
        <span class="fc-icon">✉️</span>
        <a href="mailto:mann@setuglobalsolution.com">mann@setuglobalsolution.com</a>
      </div>
      <div class="footer-contact-item">
        <span class="fc-icon">📍</span>
        <span>Ahmedabad, Gujarat, India</span>
      </div>
      <div class="footer-contact-item">
        <span class="fc-icon">🕐</span>
        <span>Mon–Sat: 10 AM – 7 PM</span>
      </div>
    </div>
  </div>

  <div class="footer-bottom">
    <span>© 2026 Setu Global Solution. All Rights Reserved.</span>
    <span>Made with ♥ for aspiring students in Ahmedabad</span>
  </div>
</footer>
