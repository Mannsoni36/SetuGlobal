---
---
<nav>
  <a href="#home" class="nav-logo">
    <img src="/setu_gloabal_logo.png" alt="Setu Global Logo" class="logo-icon" />
    <div class="logo-text">Setu Global<span>Solution</span></div>
  </a>
  <ul class="nav-links">
    <li><a href="#home">Home</a></li>
    <li><a href="#services">Services</a></li>
    <li><a href="#process">Process</a></li>
    <li><a href="#why-germany">Why Germany</a></li>
    <li><a href="#programs">Programs</a></li>
    <li><a href="#faq">FAQ</a></li>
    <li><a href="#contact">Contact</a></li>
  </ul>
  <a href="#contact" class="btn btn-primary btn-sm nav-cta">Free Consultation</a>
  <div class="hamburger">
    <span></span><span></span><span></span>
  </div>
</nav>

<div class="mobile-menu">
  <a href="#home">Home</a>
  <a href="#services">Services</a>
  <a href="#process">How It Works</a>
  <a href="#why-germany">Why Germany</a>
  <a href="#programs">Programs</a>
  <a href="#faq">FAQ</a>
  <a href="#contact">Contact</a>
  <a href="#contact" class="btn btn-primary" style="margin-top: 8px; text-align: center;">Free Consultation →</a>
</div>

<script>
  const nav = document.querySelector('nav');
  const hamburger = document.querySelector('.hamburger');
  const mobileMenu = document.querySelector('.mobile-menu');

  window.addEventListener('scroll', () => {
    nav.classList.toggle('scrolled', window.scrollY > 10);
  });

  hamburger.addEventListener('click', () => {
    hamburger.classList.toggle('open');
    mobileMenu.classList.toggle('open');
  });

  mobileMenu.querySelectorAll('a').forEach((link) => {
    link.addEventListener('click', () => {
      hamburger.classList.remove('open');
      mobileMenu.classList.remove('open');
    });
  });
</script>
